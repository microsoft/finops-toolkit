{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "adxClusterName": {
      "value": "${FINOPS_HUB_CLUSTER_NAME}"
    },
    "adxClusterResourceGroupName": {
      "value": "${FINOPS_HUB_CLUSTER_RESOURCE_GROUP}"
    },
    "deployerPrincipalType": {
      "value": "${AZURE_PRINCIPAL_TYPE}"
    },
    "finopsHubClusterUri": {
      "value": "${FINOPS_HUB_CLUSTER_URI}"
    },
    "DEPLOY_FINOPS_HUB": {
      "value": "${DEPLOY_FINOPS_HUB}"
    },
    "FINOPS_HUB_DATA_EXPLORER_SKU": {
      "value": "${FINOPS_HUB_DATA_EXPLORER_SKU}"
    }
  }
}
